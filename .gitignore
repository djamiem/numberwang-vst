# Build output
build/
cmake-build-*/

# macOS
.DS_Store
*.DS_Store

# JUCE submodule build artifacts (keep the submodule itself)
# but ignore local JUCE overrides if any

# IDE / editor
.vscode/
.idea/
*.xcodeproj/
*.xcworkspace/
*.swp
*.swo

# Compiled plugin artifacts (keep source, ignore built plugins)
*.vst3
*.component
*.aaxplugin
*.app

# Static/shared libs
*.a
*.dylib
*.so

# Object files
*.o
*.d

# CMake generated
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
install_manifest.txt
CTestTestfile.cmake

# Xcode
xcuserdata/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3
DerivedData/

# Crash logs
*.crash

# Certificates / signing
*.p12
*.cer
*.provisionprofile
